\"image_card_v2_personalized_ads_mvp_1\"},{\"key\":\"image_card_v2_personalized_ads_mvp_2\",\"label\":\"Personalized Ads MVP 2\"}]},\"is_device_based\":false,\"passed\":false},\"339548201\":{\"name\":\"339548201\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"log_every_n_events\":0,\"websocket_idle_timeout_ms\":60000,\"log_every_ms\":10000,\"ignore_parent_id_mismatch\":false},\"is_device_based\":false,\"passed\":false},\"2712016364\":{\"name\":\"2712016364\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"gcTimeMs\":1800001,\"staleTimeMs\":300001},\"is_device_based\":false,\"passed\":false},\"1249441124\":{\"name\":\"1249441124\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"2055363467\":{\"name\":\"2055363467\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_notification_rules_per_scan\":10,\"max_receivers_per_rule\":5,\"should_send\":true,\"can_configure\":true},\"is_device_based\":false,\"passed\":false},\"2302071098\":{\"name\":\"2302071098\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"videoUrl\":\"https://persistent.oaistatic.com/deep-research/nux.070152025.mp4\",\"posterUrl\":\"https://persistent.oaistatic.com/deep-research/nux.070152025.jpg\"},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"enable_web_search\":false},\"is_device_based\":false,\"passed\":false},\"1429888782\":{\"name\":\"1429888782\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"enabled\"],\"group_name\":\"Control\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2144562623\":{\"name\":\"2144562623\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"tax_types\":{\"gb_vat\":{\"placeholder\":\"GB123456789\",\"country_label\":\"United Kingdom\",\"supported\":true,\"region\":\"EEA-GB-CH\",\"type\":\"gb_vat\",\"verifiable\":true,\"country\":\"GB\",\"format\":\"GB([0-9]{9}|[0-9]{12}|(HA|GD)[0-9]{3})\",\"stripe_type\":\"gb_vat\",\"description\":\"United Kingdom VAT number\",\"rev