    .pinterestPreview.cc440d50ba-tooltiptext-bottom::after {
      border-color: transparent transparent #DBDBDB transparent;
    }

    /* Gemini divider */
    .cc440d50ba-gemini-divider {
      display: inline-block;
      width: 1px;
      height: 24px;
      background-color: rgb(225, 225, 225);
      border-radius: 2px;
      align-self: center;
      flex-shrink: 0;
    }

    /* Gemini preview divider (1×32px, always light — sits in Chrome header) */
    .cc440d50ba-gemini-preview-divider {
      display: inline-block;
      width: 1px;
      height: 32px;
      background-color: rgb(225, 225, 225);
      border-radius: 2px;
      align-self: center;
      flex-shrink: 0;
    }

    /* Gemini edit image group — flex row wrapper for [divider + button] or [button + divider] */
    .cc440d50ba-gemini-edit-image-group {
      display: flex;
      flex-direction: row;
      align-items: center;
    }

    .cc440d50ba-gemini-edit-image-group--chat-view {
      gap: 8px;
      margin-left: 8px;
    }

    .cc440d50ba-gemini-edit-image-group--preview {
      gap: 13px;
    }

    /* Gemini chat view styles */
    .geminiChatView .cc440d50ba-express-entrypoint-button {
      background-color: transparent;
      border: 2px solid rgba(0, 0, 0, 0.15);
    }

    .geminiChatView .cc440d50ba-express-entrypoint-button:hover {
      background-color: rgba(0, 0, 0, 0.05);
    }

    .geminiChatView .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-text {
      font-weight: 700;
      font-size: 14px;
    }

    /* Gemini preview mode styles */
    .geminiPreview .cc440d50ba-express-entrypoint-button {
      background-color: transparent;
      border: 1px solid rgba(255, 255, 255, 0.25);
      color: rgba(255, 255, 255, 0.9);
    }

    .geminiPreview .cc440d50ba-express-entrypoint-button:hover {
      background-color: rgba(255, 255, 255, 0.1);
    }

    .geminiPreview.cc440d50ba-tooltiptext {
      background-color: #DBDBDB;
      color: #111111;
    }

    .geminiPreview.cc440d50ba-tooltiptext-bottom::after {
      border-color: transparent transparent #DBDBDB transparent;
    }

    /* Google AI Mode chat view styles */
    .googleAiModeChatView .cc440d50ba-express-entrypoint-button {
      background-color: inherit;
      border: 2px solid;
      border-color: color-mix(in srgb, currentColor 15%, transparent);
      color: inherit;
      height: auto;
    }

    .googleAiModeChatView .cc440d50ba-express-entrypoint-button:hover {
      background-color: #e9ebf0;
    }

    .googleAiModeChatView .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-icon {
      height: auto;
      width: auto;
      padding: 0 6px 0 10px;
    }

    .googleAiModeChatView .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-icon img {
      width: 16px;
    }

    .googleAiModeChatView .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-text {
      font-weight: 700;
      font-size: 12px;
      padding: 4px 14px 6px 0px;
    }

    /* Google AI Mode preview styles */
    .googleAiModePreview .cc440d50ba-express-entrypoint-button {
      background-color: inherit;
      border:none;
      color: inherit;
      height: 36px;
      border-radius: 20px;
      display: flex;
      flex-direction: row;
      justify-content: center;
      padding: 0 24px 0 18px;
      opacity: 0.9;
    }

    .googleAiModePreview .cc440d50ba-express-entrypoint-button:hover {
      opacity: 1;
    }

    .googleAiModePreview  .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-text {
      font-weight: 400;
    }

    /* Dark mode styles */
    /* Split button (three-dot menu) styles */
    .cc440d50ba-express-three-dot-trigger {
        display: none;
        align-items: center;
        justify-content: center;
        /* 24×24 rounded square per spec — floats inside the pill */
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        align-self: center;
        margin-right: 4px;
        border-radius: 7px;
        box-sizing: border-box;
        cursor: pointer;
        /* Reset host-page button styles (ChatGPT targets role=button/tabindex) */
        border: none !important;
        outline: none !important;
        box-shadow: none !important;
        background-color: transparent;
        -webkit-appearance: none;
        appearance: none;
        color: inherit;
    }
    /* Override ChatGPT's focus ring on the trigger at all focus states */
    .cc440d50ba-express-three-dot-trigger:focus,
    .cc440d50ba-express-three-dot-trigger:focus-visible,
    .cc440d50ba-express-three-dot-trigger:focus-within {
        outline: none !important;
        border: none !important;
        box-shadow: none !important;
    }
    /* Show trigger on parent hover with #f3f3f3 background */
    .cc440d50ba-express-entrypoint-button:hover .cc440d50ba-express-three-dot-trigger.cc440d50ba-split-active {
        display: flex;
        background-color: #f3f3f3;
    }
    /* Active/selected (#d5d5d5) when menu is open */
    .cc440d50ba-express-entrypoint-button.cc440d50ba-menu-open .cc440d50ba-express-three-dot-trigger.cc440d50ba-split-active {
        display: flex;
        background-color: #d5d5d5;
    }
    /* Reduce text right-padding when ≡ is visible so pill width stays proportional */
    .cc440d50ba-split-enabled .cc440d50ba-express-entrypoint-button:hover .cc440d50ba-express-entrypoint-button-text,
    .cc440d50ba-split-enabled .cc440d50ba-express-entrypoint-button.cc440d50ba-menu-open .cc440d50ba-express-entrypoint-button-text {
        padding-right: 4px;
    }
    /* Hide tooltip when split menu is open */
    .cc440d50ba-express-entrypoint-button.cc440d50ba-menu-open .cc440d50ba-tooltiptext {
        visibility: hidden !important;
    }
    .cc440d50ba-express-split-menu {
        display: none;
        flex-direction: column;
        gap: 2px;
        position: fixed;
        background: #FFFFFF;
        border-radius: 10px;
        filter: drop-shadow(0px 0px 2px rgba(0, 0, 0, 0.12))
                drop-shadow(0px 2px 6px rgba(0, 0, 0, 0.04))
                drop-shadow(0px 4px 12px rgba(0, 0, 0, 0.08));
        padding: 8px;
        z-index: 99999;
        min-width: 140px;
        width: max-content;
        max-width: 240px;
        box-sizing: border-box;
    }
    .cc440d50ba-express-split-menu.cc440d50ba-split-menu-open {
        display: flex;
    }
    .cc440d50ba-express-split-menu-item {
        display: flex;
        align-items: center;
        height: 24px;
        padding: 0 9px;
        cursor: pointer;
        border-radius: 7px;
        box-sizing: border-box;
        outline: none;
        width: 100%;
        flex-shrink: 0;
    }
    .cc440d50ba-express-split-menu-item:hover {
        background: #e9e9e9;
    }
    .cc440d50ba-express-split-menu-item:focus-visible {
        outline: 2px solid #147AF3;
        outline-offset: -2px;
        border-radius: 7px;
    }
    .cc440d50ba-express-split-menu-item-text {
        font-family: "Adobe Clean", adobe-clean, "AdobeClean-Regular", sans-serif !important;
        font-size: 12px;
        font-weight: 500;
        line-height: 16px;
        color: #292929;
        white-space: nowrap;
    }
    /* Hide split elements in compact mode */
    .cc440d50ba-express-entrypoint-button-compact .cc440d50ba-express-split-divider,
    .cc440d50ba-express-entrypoint-button-compact .cc440d50ba-express-three-dot-trigger {
        display: none !important;
    }

    @media (prefers-color-scheme: dark) {
      .cc440d50ba-express-entrypoint-button {
        background-color: #2C2C2C;
        color: rgba(255, 255, 255, 0.9);
        border: 2px solid #4B4B4B;
      }

      .cc440d50ba-express-entrypoint-button:hover {
        background-color: #3A3A3A;
      }

      .cc440d50ba-tooltiptext {
        background-color: #DBDBDB;
        color: #111111;
      }

      .cc440d50ba-tooltiptext-bottom::after {
        border-color: transparent transparent #DBDBDB transparent;
      }

      .cc440d50ba-tooltiptext-top::after {
        border-color: #DBDBDB transparent transparent transparent;
      }

      .cc440d50ba-tooltiptext-left::after {
        border-color: transparent transparent transparent #DBDBDB;
      }

      .cc440d50ba-tooltiptext-right::after {
        border-color: transparent #DBDBDB transparent transparent;
      }

      /* ChatGPT specific dark mode overrides */
      .chatgptPreview .cc440d50ba-express-entrypoint-button,
      .chatgptChatView .cc440d50ba-express-entrypoint-button {
        background-color: #2C2C2C;
        border: 2px solid #4B4B4B;
        color: rgba(255, 255, 255, 0.9);
      }

      .chatgptPreview .cc440d50ba-express-entrypoint-button:hover,
      .chatgptChatView .cc440d50ba-express-entrypoint-button:hover {
        background-color: #3A3A3A;
      }

      /* WhatsApp dark mode */
      .whatsappHover .cc440d50ba-express-entrypoint-button {
        border: 2px solid #4B4B4B;
      }
      .whatsappPreview .cc440d50ba-express-entrypoint-button:focus-visible {
        outline: rgb(153, 200, 255) solid 2px;
      }

      /* no dark mode styles for pinterest, restore all original css styles */
      .pinterestGridView .cc440d50ba-express-entrypoint-button {
        background-color: #ffffff1c;
        color: #292929;
        border: none;
      }

      .pinterestGridView .cc440d50ba-express-entrypoint-button:hover {
        background-color: #E0E0E0;
      }

