<style>
    .cc440d50ba-express-entrypoint-button {
        display: flex;
        flex-direction: row;
        height: 32px;
        border-radius: 16px;
        position: relative;
        cursor: pointer;
        background-color: #E8E8E8;
        color: rgba(0, 0, 0, 0.84);
        align-items: center;
        box-sizing: border-box;
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
    }

