    .outlookNativeViewer .cc440d50ba-express-entrypoint-button:hover {
      background-color: rgba(0, 0, 0, 0.05);
    }

    .outlookNativeViewer .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-icon {
      width: 32px;
      height: 32px;
      padding: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .outlookNativeViewer .cc440d50ba-express-entrypoint-button .cc440d50ba-express-entrypoint-button-icon img {
      width: 20px;
      height: 20px;
