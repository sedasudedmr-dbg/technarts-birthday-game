    .pinterestPreview .cc440d50ba-express-entrypoint-button {
      height: 48px;
      border-radius: 12px;
      border: none;
      background-color: #ffffff1c;
      color: #292929;
      flex-wrap: nowrap;
      overflow: hidden;
